# URL pública de la app (opcional).
# En producción (Vercel) normalmente no hace falta.
# Útil en desarrollo si generas links para WhatsApp desde el PC hacia el móvil.
# VITE_PUBLIC_APP_URL=https://tu-app.ngrok.io

# Firebase (cliente)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Web Push (solo public key en frontend)
VITE_VAPID_PUBLIC_KEY=

# Cloudinary (opcional)
VITE_CLOUDINARY_CLOUD_NAME=
