rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: solo el propio usuario puede leer su doc
    match /users/{uid} {
      allow read, write: if request.auth.uid == uid;
    }

    // Tenants: lectura pública, escritura solo autenticados del tenant
    match /tenants/{tenantId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;

      // Professionals: lectura pública
      match /professionals/{profId} {
        allow read: if true;
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
      }

      // Services: lectura pública
      match /services/{serviceId} {
        allow read: if true;
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
      }

      // Bookings: lectura y creación públicas; update/delete solo admin, salvo acciones del cliente sin login
      match /bookings/{bookingId} {
        allow read: if true;
        allow create: if true;
        // Admin del tenant puede hacer cualquier update/delete
        allow update, delete: if request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId
        // Cliente sin login: solo subir comprobante de abono
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['depositStatus', 'depositProofUrl'])
            && request.resource.data.depositStatus == 'uploaded'
            && request.resource.data.depositProofUrl is string
            && request.resource.data.depositProofUrl.size() > 0)
        // Cliente sin login: solo cancelar (status -> cancelled desde pending o confirmed)
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
            && request.resource.data.status == 'cancelled'
            && resource.data.status in ['pending', 'confirmed']);
      }
			match /blocks/{blockId} {
  			allow read: if true;        // ← agregar lectura pública
  			allow write: if request.auth != null
    			&& 
      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
			}
      // Reseñas: cualquiera puede leer (comprobar si ya hay reseña) y crear (enviar reseña)
      // Solo usuarios del tenant pueden actualizar/eliminar (admin aprueba/rechaza)
      match /reviews/{reviewId} {
        allow read, create: if true;
        allow update, delete: if request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
      }
    }
  }
}
